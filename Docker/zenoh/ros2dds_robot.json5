{
  mode: "router",

  listen: {
    endpoints: [
      "tcp/192.168.12.1:7447#iface=wlan1",
      "tcp/0.0.0.0:7447#iface=wlan0",
      "tcp/192.168.123.161:7447#iface=eth0",
      "tcp/100.120.120.52:7447#iface=tailscale0"
    ]
  },

  scouting: {
    multicast: { enabled: false },
    gossip: { enabled: false }
  },

  plugins: {
    ros2dds: {
      domain: 43,

      // In congestione: meglio drop che accumulare latenza
      reliable_routes_blocking: false,

      // Inoltrare solo i topic utili: immagini compresse e topic di stato/controllo
      allow: {
        publishers: [
          ".*/compressed",
          ".*/compressedDepth",
          ".*/theora",
          ".*/camera_info",
          ".*/low_state",
          ".*/imu",
          ".*/joint_states",
          "/tf",
          "/tf_static",
          ".*/log",
          ".*/robot_description",
          ".*/odom",
          ".*/scan",
          "/unitree_go1/FL_foot/wrench",
          "/unitree_go1/FR_foot/wrench",
          "/unitree_go1/RL_foot/wrench",
          "/unitree_go1/RR_foot/wrench",
          "/unitree_go1/bms_state",
          "/unitree_go1/wireless_remote",
          "/unitree_go1/remote"
        ],
        subscribers: [  
          ".*/cmd_vel", 
          ".*/cmd",     
          ".*/high_cmd",
          ".*/low_cmd"   
        ],
        // ROS2 service servers exposed by the robot reachable from remote clients
        service_servers: [
          "/unitree_go1/set_face_animation",
          "/unitree_go1/set_face_color",
          "/unitree_go1/legged_sdk/enable_high",
          "/unitree_go1/legged_sdk/enable_low",
          "/unitree_go1/legged_sdk/get_status_high",
          "/unitree_go1/legged_sdk/get_status_low",
          "/unitree_go1/legged_sdk/set_high_mode",
          "/unitree_go1/sport_controller/set_mode",
        ],
        // ROS2 service clients on the robot that remote nodes can call into
        service_clients: []
      },

      // Downsampling dei topic PUBBLICATI dal robot verso Zenoh
      pub_max_frequencies: [
        ".*/compressed=15",
        ".*/compressedDepth=10",
        ".*/theora=15",
        ".*/camera_info=10",
        "/tf=20"
      ],

      // Priorità dei topic PUBBLICATI dal robot verso Zenoh
      // Scala Zenoh: 1=RealTime (più alta) → 7=Background (più bassa)
      pub_priorities: [
        ".*/low_state=1:express",   // stato robot / sicurezza — massima priorità
        ".*/imu=2:express",         // dati inerziali — alta priorità
        ".*/joint_states=2",
        "/tf=3",
        "/tf_static=3",
        ".*/camera_info=4",
        ".*/compressed=5",          // immagini compresse — dati bulk
        ".*/compressedDepth=5",
        ".*/theora=6"
      ],
    }
  }
}
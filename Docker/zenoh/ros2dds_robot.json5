{
  mode: "router",

  listen: {
    endpoints: [
      "tcp/192.168.12.1:7447#iface=wlan1",
      "tcp/0.0.0.0:7447#iface=wlan0",
      "tcp/192.168.123.161:7447#iface=eth0"
    ]
  },

  scouting: {
    multicast: { enabled: false },
    gossip: { enabled: false }
  },

  plugins: {
    ros2dds: {
      domain: 43,

      // In congestione: meglio drop che accumulare latenza
      reliable_routes_blocking: false,

      // Non inoltrare fuori dal robot le immagini raw / mono non compresse
      deny: {
        publishers: [
          ".*/image_raw",
          ".*/image_mono"
        ]
      },

      // Downsampling dei topic PUBBLICATI dal robot verso Zenoh
      pub_max_frequencies: [
        ".*/camera_info=10",
        "/tf=20"
      ],

      // Priorità dei topic PUBBLICATI dal robot verso Zenoh
      pub_priorities: [
        ".*/low_state=1:express",
        "/tf=2",
        "/tf_static=2",
        ".*/imu=2",
        ".*/joint_states=2",
        ".*/camera_info=4"
      ]
    }
  }
}